APP_NAME=Laravel
# `php artisan innout:demo-data` e simulação de horário no ponto só funcionam com APP_ENV=local
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
# Laravel na máquina + MySQL no Docker: DB_HOST=127.0.0.1 e DB_PASSWORD igual a MYSQL_ROOT_PASSWORD (ex.: secret)
# Laravel dentro do container app: o compose define DB_HOST=mysql (não precisa alterar o .env no host para isso)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=innout
DB_USERNAME=root
DB_PASSWORD=secret

# --- Docker (PHP a correr dentro do container `app`) ---
# O hostname do MySQL na rede do Compose é o nome do serviço: mysql (não use 127.0.0.1).
# Dentro do container, 127.0.0.1 é o próprio container, não o MySQL → "Connection refused".
# O docker-compose.yml já define DB_HOST=mysql para o serviço app; se montares o projeto
# inteiro em /var/www/html, garante DB_HOST=mysql e DB_PASSWORD=secret no .env.
# Apaga config em cache no host: php artisan config:clear (evita bootstrap/cache/config.php antigo).
# Nota Laravel: `php artisan serve` sem --no-reload remove DB_* do processo PHP quando existe .env;
# o entrypoint Docker usa `serve --no-reload` por isso.

# Jornada diária esperada em segundos (8h = 28800)
INNOUT_DAILY_WORK_SECONDS=28800

BROADCAST_DRIVER=log
# file = sem tabela `cache` na BD; use database + migrar 0001_01_01_000001 se preferir
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
